linters: linters_with_defaults(
    line_length_linter = line_length_linter(100L),
    object_usage_linter = NULL,
    object_name_linter = object_name_linter(
      styles = c("snake_case", "symbols")
    ),
    # The use_standalone yaml header's `# repo: ACCIDDA/flexstanr` line parses
    # as R (unlike hyphenated repos), so commented_code_linter false-positives
    # on it. Disable it rather than a fragile per-line nolint (which
    # use_standalone strips when vendoring).
    commented_code_linter = NULL,
    return_linter(
      return_style = "implicit"
    )
  )
encoding: "UTF-8"
