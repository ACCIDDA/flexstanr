linters: linters_with_defaults(
    line_length_linter = line_length_linter(100L),
    object_usage_linter = NULL,
    object_name_linter = object_name_linter(
      styles = c("snake_case", "symbols")
    ),
    # Several explanatory comments (e.g. the `# nocov start:` guards and inline
    # rstan/cmdstanr call notes) parse as R, so commented_code_linter
    # false-positives on them. Disable it rather than sprinkle nolint lines.
    commented_code_linter = NULL,
    return_linter(
      return_style = "implicit"
    )
  )
